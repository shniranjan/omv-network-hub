# ── OMV Network Hub — Environment Variables ──────────────
# Copy to .env and fill in your values

# ── Timezone ────────────────────────────────────────────
TZ=Australia/Adelaide

# ── Docker Network ──────────────────────────────────────
DOCKER_SUBNET=172.30.0.0/24

# ── Pi-hole DNS ─────────────────────────────────────────
PIHOLE_WEBPASSWORD=change...n
# ── Forward Proxy (tinyproxy) ───────────────────────────
PROXY_PORT=8888
LAN_SUBNET=192.168.0.0/16

# ── SSH Tunnel to VPS (for HA remote access)─────────────
VPS_USER=your-username
VPS_HOST=your-vps.com
VPS_SSH_PORT=22
TUNNEL_LOCAL_HOST=homeassistant
TUNNEL_LOCAL_PORT=8123
TUNNEL_REMOTE_PORT=8123
